data_warehouse:
  target: "{{ env_var('DBT_TARGET', 'dev') }}"
  outputs:
    dev: &bigquery_defaults
      type: bigquery
      method: service-account
      keyfile: "{{ env_var('DBT_GOOGLE_APPLICATION_CREDENTIALS') }}"
      project: "{{ env_var('PROJECT_ID') }}"
      dataset: "{{ env_var('DBT_DATASET') }}"
      location: "{{ env_var('BIGQUERY_LOCATION', 'US') }}"
      threads: "{{ env_var('DBT_THREADS', '4') | int }}"
      priority: interactive
      job_execution_timeout_seconds: 300
      job_retries: 1

    qa:
      <<: *bigquery_defaults

    prod:
      <<: *bigquery_defaults
