# Copy this file to the external environment config directory for QA or prod.
# Example target: $HOME/secrets/data-platform/<env>/.env
# Replace every change-me value before deploying.

AIRFLOW_UID=1000
# Set this to: stat -c '%g' /var/run/docker.sock
DOCKER_GID=0

# Use environment-specific names, for example data-platform-airflow-qa.
AIRFLOW_COMPOSE_PROJECT=data-platform-airflow-qa
AIRFLOW_API_PORT=8081

# Non-secret immutable image refs live beside this file in images.env.

POSTGRES_USER=airflow
POSTGRES_PASSWORD=change-me
POSTGRES_DB=airflow

AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_SECRET_KEY=change-me-generate-with-python-secrets
AIRFLOW_JWT_SECRET=change-me-generate-with-python-secrets
AIRFLOW_FERNET_KEY=change-me-generate-with-fernet-command

ENVIRONMENT=qa
PROJECT_ID=change-me
RAW_DATASET=raw

# Absolute host credential JSON paths on the deployment host.
SCRIPTS_GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/secrets/data-platform/qa/scripts-service-account.json
DBT_GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/secrets/data-platform/qa/dbt-service-account.json

# QA DAGs are manual-only. Prod must set a real schedule later.
ETL__PERSONAL_FINANCE_SCHEDULE=

PERSONAL_FINANCE_GSHEET_URL=https://docs.google.com/spreadsheets/d/.../edit
PERSONAL_FINANCE_GCS_BUCKET=change-me-data-platform-landing
PERSONAL_FINANCE_GCS_PREFIX=personal_finance
PERSONAL_FINANCE_CHUNK_SIZE=5000
PERSONAL_FINANCE_JSONL_RETENTION_DAYS=7

DBT_TARGET=qa
DBT_DATASET=analytics
DBT_THREADS=4
BIGQUERY_LOCATION=US
