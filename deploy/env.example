# Copy this file to the external environment config directory for QA or prod.
# Example target: $HOME/secrets/data-platform/<env>/.env
# Replace every change-me value before deploying.

AIRFLOW_UID=1000
# Set this to: stat -c '%g' /var/run/docker.sock
DOCKER_GID=0

# Use environment-specific names, for example data-platform-airflow-qa or
# data-platform-airflow-prod.
AIRFLOW_COMPOSE_PROJECT=data-platform-airflow-qa
AIRFLOW_API_PORT=8081

# Non-secret immutable image refs live beside this file in images.env.

POSTGRES_USER=airflow
POSTGRES_PASSWORD=change-me
POSTGRES_DB=airflow

AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_SECRET_KEY=change-me-generate-with-python-secrets
AIRFLOW_JWT_SECRET=change-me-generate-with-python-secrets
AIRFLOW_FERNET_KEY=change-me-generate-with-fernet-command

# Optional external UI URL used by Airflow-generated links.
# AIRFLOW__API__BASE_URL=https://airflow.kevinesg.com

# Optional Airflow failure alerts. Keep webhook URLs in this external env file.
# DATA_PLATFORM_AIRFLOW_FAILURE_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...

# Set ENVIRONMENT and DBT_TARGET to qa or prod for deployed environments.
ENVIRONMENT=qa
PROJECT_ID=change-me
RAW_DATASET=raw

# Absolute host credential JSON paths on the deployment host.
SCRIPTS_GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/secrets/data-platform/qa/scripts-service-account.json
DBT_GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/secrets/data-platform/qa/dbt-service-account.json

# QA DAGs are manual-only. Prod must set a real schedule.
ETL__PERSONAL_FINANCE_SCHEDULE=
ETL__WREMOTELY_SCHEDULE=
WREMOTELY_LIFECYCLE_SCHEDULE=

PERSONAL_FINANCE_GSHEET_URL=https://docs.google.com/spreadsheets/d/.../edit
PERSONAL_FINANCE_GCS_BUCKET=change-me-data-platform-landing
PERSONAL_FINANCE_GCS_PREFIX=personal_finance
PERSONAL_FINANCE_CHUNK_SIZE=5000
PERSONAL_FINANCE_JSONL_RETENTION_DAYS=7

DBT_TARGET=qa
DBT_DATASET=analytics
DBT_THREADS=4
BIGQUERY_LOCATION=US

# wremotely DAG runtime inputs. Keep credentials, policies, and artifacts
# outside every checkout. The reviewed source snapshot is bundled into the
# immutable private image referenced by images.env.
WREMOTELY_HANDOFF_DATASET=handoff
WREMOTELY_PUBLICATION_TOPIC=wremotely-serving-publications
WREMOTELY_ETL_GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/secrets/wremotely-etl/qa/google-application-credentials.json
WREMOTELY_ETL_ARTIFACTS_DIR=/absolute/path/to/wremotely-etl-artifacts
WREMOTELY_PUBLICATION_HOLD_POLICY=/absolute/path/to/secrets/wremotely-etl/qa/publication-hold-policy.md
WREMOTELY_GCS_BUCKET=change-me-wremotely-etl-landing
WREMOTELY_GCS_PREFIX=wremotely
WREMOTELY_BIGQUERY_LOCATION=US
WREMOTELY_SOURCE_CRAWL_WORKER_COUNT=6
WREMOTELY_EXTRACT_WORKER_COUNT=4
WREMOTELY_PLATFORM_WORKER_COUNT=2
WREMOTELY_RECHECK_WORKER_COUNT=16
WREMOTELY_PAGE_MAX_BYTES=2097152
WREMOTELY_DOMAIN_DELAY_SECONDS=1
WREMOTELY_DOMAIN_FAILURE_LIMIT=5
WREMOTELY_CRAWL4AI_FALLBACK=auto
WREMOTELY_CRAWL4AI_MIN_TEXT_CHARS=500
WREMOTELY_STAGE_CHUNK_ROW_COUNT=5000
WREMOTELY_KNOWN_URL_LOOKBACK_DAYS=365
WREMOTELY_DOCKER_NETWORK_MODE=host
# Required only when WREMOTELY_LOCAL_LLM_RUNTIME=groq. Keep the real key outside Git.
# GROQ_API_KEY=change-me
WREMOTELY_LOCAL_LLM_RUNTIME=groq
WREMOTELY_LOCAL_LLM_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
WREMOTELY_LOCAL_LLM_ENDPOINT=https://api.groq.com/openai/v1
WREMOTELY_LOCAL_LLM_TIMEOUT_SECONDS=60
