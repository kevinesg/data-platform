# Merge these values into the external dev environment file, not into this repo.
# The default path is $HOME/dev/secrets/data-platform/.env.
AIRFLOW_UID=50000
# Set DOCKER_GID to the host Docker socket group id so DockerOperator can use
# the mounted Docker socket while Airflow runs as a non-root user.
DOCKER_GID=0

AIRFLOW_COMPOSE_PROJECT=data-platform-airflow-dev
AIRFLOW_API_PORT=8080
DATA_PLATFORM_AIRFLOW_IMAGE=data-platform-airflow:dev
DATA_PLATFORM_SCRIPTS_IMAGE=data-platform-scripts:dev
DATA_PLATFORM_DBT_IMAGE=data-platform-dbt:dev
DATA_PLATFORM_WREMOTELY_ETL_IMAGE=ghcr.io/<owner>/wremotely-etl:dev

PROJECT_ID=change-me
RAW_DATASET=raw_developername
DBT_TARGET=dev
DBT_DATASET=dbt_<developer>
BIGQUERY_LOCATION=US
DBT_GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/dbt-service-account.json

POSTGRES_USER=airflow
# Keep this stable after the Postgres metadata volume is initialized. Changing
# it later requires recreating the local Airflow Compose volumes.
POSTGRES_PASSWORD=change-me
POSTGRES_DB=airflow

AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_SECRET_KEY=change-me-generate-with-python-secrets
AIRFLOW_JWT_SECRET=change-me-generate-with-python-secrets
AIRFLOW_FERNET_KEY=change-me-generate-with-fernet-command

# Optional external UI URL used by Airflow-generated links.
# AIRFLOW__API__BASE_URL=http://localhost:8080

# Optional failure alerts. Keep webhook URLs in the external environment file.
# DATA_PLATFORM_AIRFLOW_FAILURE_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...

# Prod-only DAG schedules.
# ETL__PERSONAL_FINANCE_SCHEDULE=0 20 * * *
# ETL__WREMOTELY_SCHEDULE=0 */6 * * *

# wremotely DAG runtime inputs. Keep all paths outside this repository.
WREMOTELY_ETL_GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/wremotely-etl-service-account.json
WREMOTELY_ETL_ARTIFACTS_DIR=/absolute/path/to/wremotely-etl-artifacts
WREMOTELY_APPROVED_SOURCES_FILE=/absolute/path/to/approved_sources.jsonl
WREMOTELY_APPROVED_SOURCES_SHA256=change-me
WREMOTELY_PUBLICATION_HOLD_POLICY=/absolute/path/to/publication-hold-policy.md
WREMOTELY_GCS_BUCKET=change-me
WREMOTELY_GCS_PREFIX=wremotely
WREMOTELY_BIGQUERY_LOCATION=US
WREMOTELY_EXTRACT_WORKER_COUNT=4
WREMOTELY_PAGE_MAX_BYTES=2097152
WREMOTELY_DOMAIN_DELAY_SECONDS=1
WREMOTELY_DOMAIN_FAILURE_LIMIT=5
WREMOTELY_CRAWL4AI_FALLBACK=auto
WREMOTELY_CRAWL4AI_MIN_TEXT_CHARS=500
WREMOTELY_STAGE_CHUNK_ROW_COUNT=5000
WREMOTELY_KNOWN_URL_LOOKBACK_DAYS=365
WREMOTELY_SOURCE_CRAWL_SHARD_COUNT=1
WREMOTELY_SOURCE_CRAWL_SHARD_INDEX=0
WREMOTELY_DOCKER_NETWORK_MODE=host
WREMOTELY_LOCAL_LLM_RUNTIME=ollama
WREMOTELY_LOCAL_LLM_MODEL=change-me
WREMOTELY_LOCAL_LLM_ENDPOINT=http://127.0.0.1:11434
WREMOTELY_LOCAL_LLM_TIMEOUT_SECONDS=120
