# Merge these values into the external dev environment file, not into this repo.
# The default path is $HOME/dev/secrets/data-platform/.env.
AIRFLOW_UID=50000
# Set DOCKER_GID to the host Docker socket group id so DockerOperator can use
# the mounted Docker socket while Airflow runs as a non-root user.
DOCKER_GID=0

AIRFLOW_COMPOSE_PROJECT=data-platform-airflow-dev
AIRFLOW_API_PORT=8080
DATA_PLATFORM_AIRFLOW_IMAGE=data-platform-airflow:dev
DATA_PLATFORM_SCRIPTS_IMAGE=data-platform-scripts:dev
DATA_PLATFORM_DBT_IMAGE=data-platform-dbt:dev

POSTGRES_USER=airflow
# Keep this stable after the Postgres metadata volume is initialized. Changing
# it later requires recreating the local Airflow Compose volumes.
POSTGRES_PASSWORD=change-me
POSTGRES_DB=airflow

AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_SECRET_KEY=change-me-generate-with-python-secrets
AIRFLOW_JWT_SECRET=change-me-generate-with-python-secrets
AIRFLOW_FERNET_KEY=change-me-generate-with-fernet-command
