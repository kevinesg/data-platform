## Copy this file to an external secrets directory as metabase.env.
## Example local target: $HOME/dev/secrets/data-platform/metabase.env
## Example deployed target: $HOME/secrets/data-platform/prod/metabase.env

METABASE_COMPOSE_PROJECT=data-platform-metabase
METABASE_IMAGE=metabase/metabase:v0.62.1.2
METABASE_BIND_ADDRESS=127.0.0.1
METABASE_PORT=3000

MB_SITE_NAME=Data Platform
MB_SITE_URL=http://localhost:3000
MB_DB_TYPE=postgres
MB_DB_HOST=postgres
MB_DB_PORT=5432
MB_DB_DBNAME=metabase
MB_DB_USER=metabase
MB_DB_PASS=change-me
MB_ENCRYPTION_SECRET_KEY=change-me-generate-with-openssl-rand-base64-32
MB_ANON_TRACKING_ENABLED=false

JAVA_TIMEZONE=Asia/Manila
